{
  "name": "agentic-wiki",
  "version": "0.1.0",
  "description": "Agent-driven code-to-wiki transformation engine",
  "type": "module",
  "scripts": {
    "scan:project": "npx tsx src/lib/scan-project.ts",
    "scan:files": "npx tsx src/lib/scan-files.ts",
    "scan:folders": "npx tsx src/lib/analyze-folders.ts",
    "scan:filter": "npx tsx src/lib/filter-styles.ts",
    "deps:build": "npx tsx src/lib/build-deps.ts",
    "deps:extract": "npx tsx src/lib/extract-subgraph.ts",
    "deps:diff": "npx tsx src/lib/git-diff.ts",
    "ast:parse": "npx tsx src/lib/parse-ast.ts",
    "hash:compute": "npx tsx src/lib/compute-hashes.ts",
    "wiki:update": "npx tsx src/lib/update-wiki-section.ts",
    "wiki:validate": "npx tsx src/lib/validate-references.ts",
    "validate:artifacts": "npx tsx src/lib/validate-artifacts.ts",
    "validate:issues": "npx tsx src/lib/validate-issue-types.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@babel/parser": "^7.27.3",
    "@babel/traverse": "^7.27.3",
    "dependency-cruiser": "^16.8.0",
    "fs-extra": "^11.3.0",
    "globby": "^14.1.0",
    "gray-matter": "^4.0.3",
    "precinct": "^12.1.0",
    "remark": "^15.0.1",
    "simple-git": "^3.27.0",
    "unist-util-visit": "^5.0.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/yargs": "^17.0.33",
    "@vitest/coverage-v8": "^3.2.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
