{
  "name": "agentic-wiki",
  "version": "0.2.0",
  "description": "Agent-driven code-to-wiki transformation engine",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "scan:project": "npx tsx src/lib/scan-project.ts",
    "scan:files": "npx tsx src/lib/scan-files.ts",
    "scan:filter": "npx tsx src/lib/filter-styles.ts",
    "scan:priorities": "npx tsx src/lib/file-priorities.ts",
    "scan:folders": "npx tsx src/lib/analyze-folders.ts",
    "deps:build": "npx tsx src/lib/build-deps.ts",
    "deps:extract": "npx tsx src/lib/extract-subgraph.ts",
    "deps:diff": "npx tsx src/lib/git-diff.ts",
    "hash:compute": "npx tsx src/lib/compute-hashes.ts",
    "wiki:validate": "npx tsx src/lib/validate-references.ts",
    "validate:artifacts": "npx tsx src/lib/validate-artifacts.ts",
    "validate:issues": "npx tsx src/lib/validate-issue-types.ts",
    "validate:issue-content": "npx tsx src/lib/validate-issue-content.ts",
    "validate:paths": "npx tsx src/lib/validate-paths.ts",
    "fix:issues": "npx tsx src/lib/fix-issue-paths.ts",
    "gen:schedule": "npx tsx src/lib/gen-scheduler.ts",
    "gen:verify": "npx tsx src/lib/verify-gen-artifacts.ts",
    "gen:progress": "npx tsx src/lib/progress-dashboard.ts",
    "gen:sync": "npx tsx src/lib/sync-gen-tasks.ts",
    "state:transition": "npx tsx src/lib/state-manager.ts transition",
    "assemble:book": "npx tsx src/lib/assemble-book.ts",
    "assemble:dashboard": "npx tsx src/lib/issue-dashboard.ts",
    "assemble:symbols": "npx tsx src/lib/symbol-index.ts",
    "validate:code-refs": "npx tsx src/lib/validate-code-refs.ts",
    "route:check": "npx tsx src/lib/route-check.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@babel/parser": "^7.27.3",
    "@babel/traverse": "^7.27.3",
    "dependency-cruiser": "^16.8.0",
    "fs-extra": "^11.3.0",
    "globby": "^14.1.0",
    "gray-matter": "^4.0.3",
    "precinct": "^12.1.0",
    "remark": "^15.0.1",
    "simple-git": "^3.27.0",
    "unist-util-visit": "^5.0.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/yargs": "^17.0.33",
    "@vitest/coverage-v8": "^3.2.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
